# mcp-gemini-search project generated files to ignore
#  If you want to ignore files created by your editor/tools,
#  please consider a global .gitignore https://docs.github.com/en/get-started/git-basics/ignoring-files.
#  PLEASE DO NOT open a pull request to add something created by your editor or tools

# github/gitignore/Python
#
# Byte-compiled / optimized / cached files
__pycache__/
*.py[cod]

# Virtual environment
.venv/

# Packaging and build artifacts
build/
dist/
*.egg-info/

# Tool caches
.pytest_cache/
.ruff_cache/
.benchmarks/

# Editor/IDE
# .idea/
# .vscode/

# Code coverage reports
.coverage
coverage.*
htmlcov/

# benchmark
old.txt
new.txt
bench.txt
